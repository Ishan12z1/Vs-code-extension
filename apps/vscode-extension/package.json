{
  "name": "vscode-control-agent",
  "displayName": "VS Code Control Agent",
  "description": "A VS Code-native assistant for explaining and safely configuring the VS Code ecosystem.",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onView:controlAgent.sidebarView",
    "onCommand:controlAgent.hello",
    "onCommand:controlAgent.inspectWorkspaceSnapshot",
    "onCommand:controlAgent.explainWorkspace",
    "onCommand:controlAgent.openSidebar"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "controlAgent",
          "title": "Control Agent",
          "icon": "media/control-agent.svg"
        }
      ]
    },
    "views": {
      "controlAgent": [
        {
          "type": "webview",
          "id": "controlAgent.sidebarView",
          "name": "Assistant"
        }
      ]
    },
    "commands": [
      {
        "command": "controlAgent.hello",
        "title": "Control Agent: Hello"
      },
      {
        "command": "controlAgent.inspectWorkspaceSnapshot",
        "title": "Control Agent: Inspect Workspace Snapshot"
      },
      {
        "command": "controlAgent.explainWorkspace",
        "title": "Control Agent: Explain Current VS Code Setup"
      },
      {
        "command": "controlAgent.openSidebar",
        "title": "Control Agent: Open Sidebar"
      }
    ],
    "configuration": {
      "title": "VS Code Control Agent",
      "properties": {
        "controlAgent.backendUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8000",
          "description": "Backend base URL used by the extension."
        },
        "controlAgent.enableDebugLogs": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose extension-host logging."
        }
      }
    }
  },
  "scripts": {
    "clean": "rimraf dist dist-tests",
    "build": "tsc -p .",
    "build:test": "tsc -p tsconfig.test.json",
    "watch": "tsc -w -p .",
    "test": "npm run build:test && node --test \"dist-tests/tests/**/*.js\"",
    "lint": "eslint \"src/**/*.ts\"",
    "package": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@control-agent/contracts": "0.0.1",
    "jsonc-parser": "^3.3.1"
  }
}
