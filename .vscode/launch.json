{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run VS Code Control Agent",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/apps/vscode-extension",
        "--disable-extensions"
      ],
      "outFiles": ["${workspaceFolder}/apps/vscode-extension/dist/**/*.js"],
      "preLaunchTask": "npm: build - apps/vscode-extension"
    }
  ]
}
